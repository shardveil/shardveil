{
  "private": true,
  "name": "shardveil",
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "turbo": "^2.5.4",
    "prettier": "^3.5.3"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "services:logs": "docker compose logs -f"
  }
}
