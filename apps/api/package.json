    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shardveil/config": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
