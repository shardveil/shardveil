{
  "name": "@shardveil/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@prisma/client": "^5.22.0",
    "@shardveil/contracts": "workspace:*",
    "@shardveil/shared": "workspace:*",
    "hono": "^4.0.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shardveil/config": "workspace:*",
    "@types/node": "^20.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "viem": "^2.49.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  }
}
