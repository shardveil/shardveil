# =============================================================================
# ShardVeil Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# ---------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# ---------------------------------------------------------------------------
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>?schema=public
DATABASE_URL=postgresql://shardveil:shardveil@localhost:5432/shardveil?schema=public

# ---------------------------------------------------------------------------
# Redis (BullMQ job queues)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# JWT / Auth
# ---------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Ethereum / EVM (optional — set when integrating on-chain features)
# ---------------------------------------------------------------------------
# RPC endpoint for the target network (e.g. Hardhat, Sepolia, Mainnet)
ETH_RPC_URL=http://localhost:8545

# ShardVeil smart-contract address (deployed)
# CONTRACT_ADDRESS=0x...

# Private key for signing transactions (local dev only)
# PRIVATE_KEY=your_private_key_here  # Never use a funded mainnet key in dev

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=debug
